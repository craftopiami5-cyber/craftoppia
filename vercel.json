{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/admin",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/dashboard.html",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/login.css",
      "dest": "/public/login.css"
    },
    {
      "src": "/dashboard.css",
      "dest": "/public/dashboard.css"
    },
    {
      "src": "/login.js",
      "dest": "/public/login.js"
    },
    {
      "src": "/dashboard.js",
      "dest": "/public/dashboard.js"
    },
    {
      "src": "/certificate_border.jpg",
      "dest": "/public/certificate_border.jpg"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
