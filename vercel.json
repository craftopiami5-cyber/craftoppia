{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/**",
          "NotoSansEthiopic-Bold.ttf",
          "NotoSansEthiopic-Regular.ttf",
          "api/IMG_0892.PNG",
          "api/IMG_6757.html"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
